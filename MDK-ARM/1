/* Q1.31 fixed-point conversion constants */
#define CORDIC_Q31_SCALE      2147483648.0f    /* 2^31                           */
#define CORDIC_Q31_SCALE_INV  4.656612873e-10f /* 1 / 2^31                       */

/*
 * Pre-computed CORDIC CSR register values for each mode.
 * Direct register write avoids HAL_CORDIC_Calculate() bug:
 *   HAL skips RRDY wait when NbCalc=1, reading garbage before CORDIC finishes.
 */
#define CORDIC_CSR_COS  (CORDIC_FUNCTION_COSINE                     \
                         | CORDIC_PRECISION_6CYCLES                 \
                         | CORDIC_SCALE_0                           \
                         | CORDIC_INSIZE_32BITS                     \
                         | CORDIC_OUTSIZE_32BITS                    \
                         | CORDIC_NBWRITE_1      /* NARGS=0: 1 in  */ \
                         | CORDIC_NBREAD_2)      /* NRES =1: 2 out */

#define CORDIC_CSR_MOD  (CORDIC_FUNCTION_MODULUS                    \
                         | CORDIC_PRECISION_6CYCLES                 \
                         | CORDIC_SCALE_0                           \
                         | CORDIC_INSIZE_32BITS                     \
                         | CORDIC_OUTSIZE_32BITS                    \
                         | CORDIC_NBWRITE_2      /* NARGS=1: 2 in  */ \
                         | CORDIC_NBREAD_1)      /* NRES =0: 1 out */

/* Track current CORDIC mode to avoid redundant CSR writes */
static uint32_t cordic_current_mode = 0xFF; /* 0=Cos, 1=Modulus, 0xFF=uninit */

