/**
  * @brief  Compute sine & cosine via CORDIC hardware (Cosine mode, Q1.31)
  * @note   Uses direct register access — avoids HAL_CORDIC_Calculate()
  *         NbCalc=1 bug (missing RRDY poll for single-shot).
  * @param  angle_rad  Input angle in radians, auto-normalized to [-PI, PI)
  * @param  pSin       Pointer to output sine value
  * @param  pCos       Pointer to output cosine value
  */
void CORDIC_SinCos(float angle_rad, float *pSin, float *pCos)
{
    /* 1. Switch CORDIC to Cosine mode if not already configured */
    if (cordic_current_mode != 0) {
        CORDIC->CSR = CORDIC_CSR_COS;
        cordic_current_mode = 0;
    }

    /* 2. Normalize angle to [-PI, PI) for Q1.31 representation */
    float a = angle_rad;
    while (a >= PI)  a -= _2PI;
    while (a < -PI)  a += _2PI;

    /* 3. Write angle in Q1.31 — starts computation */
    CORDIC->WDATA = (int32_t)((a / PI) * CORDIC_Q31_SCALE);

    /* 4. Wait for result ready */
    while (!(CORDIC->CSR & CORDIC_CSR_RRDY));

    /* 5. Read cos (first), sin (second) in Q1.31 */
    *pCos = (float)(int32_t)CORDIC->RDATA * CORDIC_Q31_SCALE_INV;
    *pSin = (float)(int32_t)CORDIC->RDATA * CORDIC_Q31_SCALE_INV;
}

/**
  * @brief  Compute sqrt(x^2 + y^2) via CORDIC hardware (Modulus mode, Q1.31)
  * @note   Uses direct register access — avoids HAL_CORDIC_Calculate()
  *         NbCalc=1 bug (missing RRDY poll for single-shot).
  * @param  x  First value
  * @param  y  Second value
  * @return    sqrt(x^2 + y^2)
  */
float CORDIC_Modulus(float x, float y)
{
    /* 1. Switch CORDIC to Modulus mode if not already configured */
    if (cordic_current_mode != 1) {
        CORDIC->CSR = CORDIC_CSR_MOD;
        cordic_current_mode = 1;
    }

    /* 2. Scale inputs to fit Q1.31 range [-1, 1) */
    float abs_x = fabsf(x);
    float abs_y = fabsf(y);
    float max_val = (abs_x > abs_y) ? abs_x : abs_y;
    if (max_val < 1e-12f) return 0.0f;

    float x_norm = x / max_val;
    float y_norm = y / max_val;

    /* 3. Write x, y in Q1.31 — second write starts computation */
    CORDIC->WDATA = (int32_t)(x_norm * CORDIC_Q31_SCALE);
    CORDIC->WDATA = (int32_t)(y_norm * CORDIC_Q31_SCALE);

    /* 4. Wait for result ready */
    while (!(CORDIC->CSR & CORDIC_CSR_RRDY));

    /* 5. Read modulus in Q1.31 and restore scale */
    float result = (float)(int32_t)CORDIC->RDATA * CORDIC_Q31_SCALE_INV;
    return result * max_val;
}

